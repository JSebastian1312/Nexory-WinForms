        <Tables>
          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="ClienteTableAdapter" GeneratorDataComponentClassName="ClienteTableAdapter" Name="Cliente" UserDataComponentName="ClienteTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="DB_FacturacionConnectionString1 (Settings)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT 
    C.ClienteID,
    C.Nombre AS ClienteNombre,
    C.CUIT_CUIL AS ClienteCUIT_CUIL,
    C.Domicilio AS ClienteDomicilio,
    L1.Nombre AS ClienteLocalidad,
    P1.Nombre AS ClienteProvincia,
    CV.Descripcion AS ClienteCondicionVenta,
    CI.Descripcion AS ClienteCondicionIVA,

    E.EmpresaID,
    E.Nombre AS EmpresaNombre,
    E.CUIT AS EmpresaCUIT,
    E.Domicilio AS EmpresaDomicilio,
    L2.Nombre AS EmpresaLocalidad,
    P2.Nombre AS EmpresaProvincia,
    CIE.Descripcion AS EmpresaCondicionIVA

FROM Cliente AS C
    INNER JOIN Localidad AS L1 ON C.LocalidadID = L1.LocalidadID
    INNER JOIN Provincia AS P1 ON L1.ProvinciaID = P1.ProvinciaID
    INNER JOIN CondicionVenta AS CV ON C.CondicionVentaID = CV.CondicionVentaID
    INNER JOIN CondicionIVA AS CI ON C.CondicionIVAID = CI.CondicionIVAID

    CROSS JOIN (
        SELECT TOP 1 
            EmpresaID,
            Nombre,
            CUIT,
            Domicilio,
            LocalidadID,
            CondicionIVAID
        FROM Empresa
        ORDER BY EmpresaID
    ) AS E
    INNER JOIN Localidad AS L2 ON E.LocalidadID = L2.LocalidadID
    INNER JOIN Provincia AS P2 ON L2.ProvinciaID = P2.ProvinciaID
    INNER JOIN CondicionIVA AS CIE ON E.CondicionIVAID = CIE.CondicionIVAID

WHERE C.Activo = 1

ORDER BY C.Nombre;
</CommandText>
