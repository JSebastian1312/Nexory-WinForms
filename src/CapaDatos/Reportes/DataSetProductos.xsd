              <Mapping SourceColumn="EmpresaDomicilio" DataSetColumn="EmpresaDomicilio" />
              <Mapping SourceColumn="EmpresaLocalidad" DataSetColumn="EmpresaLocalidad" />
              <Mapping SourceColumn="EmpresaProvincia" DataSetColumn="EmpresaProvincia" />
              <Mapping SourceColumn="EmpresaCondicionIVA" DataSetColumn="EmpresaCondicionIVA" />
            </Mappings>
            <Sources />
